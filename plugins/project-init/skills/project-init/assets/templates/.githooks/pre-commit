#!/bin/bash
# pre-commit: CLAUDE.md에 등록된 린트 명령어를 자동 실행한다.
# 명령어가 없거나 # TBD 이면 스킵한다.

PROJECT_ROOT="$(git rev-parse --show-toplevel)"
CLAUDE_MD="$PROJECT_ROOT/CLAUDE.md"

if [ ! -f "$CLAUDE_MD" ]; then
    exit 0
fi

# 비밀 파일 커밋 차단 (.gitignore 가 깨져도 동작하는 2차 방어)
# 정책은 dangerous_bash_check / secret_read_guard 의 시크릿 파일 목록과 동일 계열.
SECRET_STAGED=$(git diff --cached --name-only | while IFS= read -r f; do
    base="${f##*/}"
    case "$base" in
        .env.example|.env.sample|.env.template|.env.dist) ;;
        .env|.env.*) echo "$f" ;;
        id_rsa*|id_ed25519*|id_ecdsa*|id_dsa*) echo "$f" ;;
        *.pem|*.key|*.p12|*.pfx|*.jks|*.keystore) echo "$f" ;;
        credentials.json|token.json|secrets.yaml|secrets.yml|secrets.json|secrets.toml) echo "$f" ;;
        .netrc|.pgpass|.pypirc) echo "$f" ;;
    esac
done)
if [ -n "$SECRET_STAGED" ]; then
    echo "[pre-commit] 🚫 차단: 비밀 파일이 스테이징되어 있습니다:" >&2
    echo "$SECRET_STAGED" | sed 's/^/  /' >&2
    echo "[pre-commit] 비밀값은 .env(git 미추적)에 두고, docs에는 키 이름만 기록하세요." >&2
    echo "[pre-commit] 정말 의도한 커밋이면 git commit --no-verify 로 우회." >&2
    exit 1
fi

# decisions.md append-only 보호: 줄 삭제 감지
DECISIONS="docs/decisions.md"
if git diff --cached --name-only | grep -q "^$DECISIONS$"; then
    DELETED=$(git diff --cached "$DECISIONS" | grep "^-" | grep -v "^---" | wc -l)
    if [ "$DELETED" -gt 0 ]; then
        echo "[pre-commit] 오류: $DECISIONS 에서 줄이 삭제되었습니다. append-only 파일입니다." >&2
        exit 1
    fi
fi

# 대량 본문 축소 경고 (advisory, 비차단): 추적 파일이 절반 미만으로 줄면 알림.
# 통째 덮어쓰기·실수 truncate를 커밋 직전에 가시화한다. 정당한 축소(파일 분할·
# 생성물 재생성 등)일 수 있으므로 차단하지 않고 경고만 한다.
SHRUNK=$(git diff --cached --numstat | awk -F'\t' '
    $1 ~ /^[0-9]+$/ && $2 ~ /^[0-9]+$/ {
        added = $1; removed = $2;
        if (removed >= 50 && added < removed * 0.5)
            print "  " $3 " (-" removed " / +" added ")"
    }')
if [ -n "$SHRUNK" ]; then
    echo "[pre-commit] 경고: 다음 파일이 대폭 축소되었습니다 — 의도한 변경인지 확인하세요:" >&2
    echo "$SHRUNK" >&2
    echo "[pre-commit] 의도한 변경이면 그대로 커밋하세요 (차단하지 않음)." >&2
fi

# 임시 파일 커밋 방어: docs/constraints.yaml 의 temp_patterns 기준
if command -v python3 &>/dev/null; then
    TEMP_STAGED=$(PROJECT_ROOT="$PROJECT_ROOT" python3 << 'PYEOF'
import subprocess, os
from pathlib import Path

root = Path(os.environ['PROJECT_ROOT'])
try:
    import yaml
    with open(root / 'docs' / 'constraints.yaml') as f:
        data = yaml.safe_load(f) or {}
    p = data.get('temp_patterns', {})
    # debug_/_debug 는 기본 제외 — 정식 소스(*_debug.h 등)와 오탐. 잡으려면 constraints.yaml 에 opt-in.
    prefixes = p.get('prefixes', ['tmp_', 'scratch_'])
    suffixes = p.get('suffixes', ['_tmp', '_scratch'])
except Exception:
    prefixes = ['tmp_', 'scratch_']
    suffixes = ['_tmp', '_scratch']

staged = subprocess.run(
    ['git', 'diff', '--cached', '--name-only'],
    capture_output=True, text=True
).stdout.strip().splitlines()
found = []
for path in staged:
    base = path.rsplit('/', 1)[-1]
    stem = base.rsplit('.', 1)[0] if '.' in base else base
    if any(base.startswith(px) for px in prefixes) or any(stem.endswith(sx) for sx in suffixes):
        found.append(path)
print('\n'.join(found))
PYEOF
)
    if [ -n "$TEMP_STAGED" ]; then
        echo "[pre-commit] 경고: 임시 파일이 스테이징에 포함되어 있습니다:" >&2
        echo "$TEMP_STAGED" | sed 's/^/  /' >&2
        echo "[pre-commit] 의도한 커밋이면 git commit --no-verify 로 우회하세요." >&2
        exit 1
    fi
fi

# CLAUDE.md 명령어 섹션에서 lint 명령을 모두 추출한다.
# - 단독 린터/타입체커: ruff, eslint, tsc 등
# - npm/pnpm/yarn/bun 스크립트는 lint 만 매칭 (build/test 오실행 방지)
LINT_CMDS=$(grep -E "^\s*((ruff|pylint|flake8|eslint|tsc|mypy|black|isort)\b|(npm|pnpm|yarn|bun)(\s+run)?\s+lint\b)" "$CLAUDE_MD" 2>/dev/null | sed 's/^[[:space:]]*//')

if [ -z "$LINT_CMDS" ]; then
    echo "[pre-commit] 경고: CLAUDE.md에 등록된 lint 명령이 없어 lint 검증을 건너뜁니다." >&2
    exit 0
fi

# 매칭된 lint 명령을 모두 실행한다 (백엔드+프론트 동시 게이트). 첫 실패에서 멈추지
# 않고 전부 돌려 위반을 한 번에 보여준다.
LINT_FAILED=0
while IFS= read -r LINT_CMD; do
    [ -z "$LINT_CMD" ] && continue
    echo "[pre-commit] 린트 실행: $LINT_CMD"
    eval "$LINT_CMD" || { echo "[pre-commit] 린트 실패: $LINT_CMD" >&2; LINT_FAILED=1; }
done <<< "$LINT_CMDS"

if [ "$LINT_FAILED" -ne 0 ]; then
    echo "[pre-commit] 린트 실패. 오류를 수정 후 다시 커밋하세요." >&2
    exit 1
fi
