#!/bin/bash
# pre-commit: CLAUDE.md에 등록된 린트 명령어를 자동 실행한다.
# 명령어가 없거나 # TBD 이면 스킵한다.

PROJECT_ROOT="$(git rev-parse --show-toplevel)"
CLAUDE_MD="$PROJECT_ROOT/CLAUDE.md"

if [ ! -f "$CLAUDE_MD" ]; then
    exit 0
fi

# decisions.md append-only 보호: 줄 삭제 감지
DECISIONS="docs/decisions.md"
if git diff --cached --name-only | grep -q "^$DECISIONS$"; then
    DELETED=$(git diff --cached "$DECISIONS" | grep "^-[^-]" | wc -l)
    if [ "$DELETED" -gt 0 ]; then
        echo "[pre-commit] 오류: $DECISIONS 에서 줄이 삭제되었습니다. append-only 파일입니다." >&2
        exit 1
    fi
fi

LINT_CMD=$(grep -E "^\s*(ruff|pylint|flake8|eslint|tsc|mypy|black|isort)\b" "$CLAUDE_MD" 2>/dev/null | head -1 | sed 's/^[[:space:]]*//')

if [ -z "$LINT_CMD" ]; then
    exit 0
fi

echo "[pre-commit] 린트 실행: $LINT_CMD"
eval "$LINT_CMD" || { echo "[pre-commit] 린트 실패. 오류를 수정 후 다시 커밋하세요." >&2; exit 1; }
